{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@schemas/*": ["src/schemas/*"]
    }
  },
  "include": ["src/**/*", "scripts/**/*", "config/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
